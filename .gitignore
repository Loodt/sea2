# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
build/
dist/
.venv/
venv/
env/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/

# Project data
projects/
*.log
*.err.log

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/

# Local data stores
*.db
*.sqlite
*.sqlite-shm
*.sqlite-wal

# Corpora — the actual document binaries are reproducible from manifest.json
corpora/*/*.pdf
corpora/*/*.html
corpora/*/*.htm
corpora/*/*.txt
corpora/*/*.md
!corpora/*/README.md
corpora/*/index.sqlite

# Comparison-blind: A/B mapping is sealed locally, must NOT leak into git
comparison-blind/.mapping
comparison-blind/expected.md
comparison-blind/m11-m12.json

# Env
.env
.env.*
!.env.example
